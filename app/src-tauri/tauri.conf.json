{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kataribe",
  "version": "0.1.0",
  "identifier": "jp.kataribe.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kataribe — 語り部",
        "width": 1100,
        "height": 800,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
