# Kataribe — クラウド LLM ナレーター設定の雛形
# このファイルを .env にコピーして値を埋める。.env は gitignore 済 (キーは絶対にコミットしない)。

# LLM エンドポイント (末尾 /v1 まで)
#   OpenAI:    https://api.openai.com/v1
#   Anthropic: https://api.anthropic.com/v1   (自動でネイティブ Messages API + prompt caching)
#   ローカル:  http://localhost:11434/v1      (Ollama 等)
LLM_BASE_URL=https://api.openai.com/v1

# ワイヤプロトコル (通常は設定不要 = base_url から自動判定)。
# api.anthropic.com はネイティブ Messages API (prompt caching が効き入力コストが大幅減、
# failures.md #44)、それ以外は OpenAI 互換 chat/completions。強制したい時だけ明示:
# LLM_PROVIDER=anthropic   # または openai

# API キー (必須)。これが無いと LlmConfig::from_env() は Config エラーを返す。
LLM_API_KEY=

# モデル。tool-use が堅いものを推奨 (例: Claude Opus 4.8 / gpt-4o)。
LLM_MODEL=gpt-4o-mini

# tool-use 強制の切替 (既定 true)。tool_choice を実装しないサーバ
# (さくら AI Engine / ローカル OpenAI 互換) では false にすると
# JSON 指示 + content フォールバック経路になる (failures.md #29)。
# LLM_USE_TOOLS=true

# xAI (Grok) を使う場合:
#   LLM_BASE_URL=https://api.x.ai/v1
#   LLM_MODEL=grok-4
# tool-use 対応は schema 自己完結化 + authored 専権 op 除外で修正済 (failures.md 参照) だが、
# 壊れ ops (move to:adjust_stat 等) が残るなら LLM_USE_TOOLS=false との A/B で切り分ける。

# 任意 (既定値あり)
# LLM_TEMPERATURE: 設定すると送信する。**新しめのモデル (claude-opus-4-8 等) は
# temperature 非対応で 400 を返す**ため、既定では送らない (コメントアウトのまま)。
# 旧来モデルで温度を効かせたい時だけ有効化する。
# LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT_SECS=120
LLM_MAX_RETRIES=3
