# Kataribe — クラウド LLM ナレーター設定の雛形
# このファイルを .env にコピーして値を埋める。.env は gitignore 済 (キーは絶対にコミットしない)。

# LLM エンドポイント (末尾 /v1 まで)
#   OpenAI:    https://api.openai.com/v1
#   Anthropic: https://api.anthropic.com/v1   (自動でネイティブ Messages API + prompt caching)
#   ローカル:  http://localhost:11434/v1      (Ollama 等)
LLM_BASE_URL=https://api.openai.com/v1

# ワイヤプロトコル (通常は設定不要 = base_url から自動判定)。
# api.anthropic.com はネイティブ Messages API (prompt caching が効き入力コストが大幅減、
# failures.md #44)、それ以外は OpenAI 互換 chat/completions。強制したい時だけ明示:
# LLM_PROVIDER=anthropic   # または openai
# 自前プロキシ経由 (判定不能なホスト名) で Anthropic を話す場合は必ず明示すること
# (未指定だと OpenAI 互換に落ちる = 安全側だが caching が効かない)。

# API キー (必須)。これが無いと LlmConfig::from_env() は Config エラーを返す。
LLM_API_KEY=

# モデル。tool-use が堅いものを推奨 (例: Claude Opus 4.8 / gpt-4o)。
LLM_MODEL=gpt-4o-mini

# tool-use 強制の切替 (既定 true)。tool_choice を実装しないサーバ
# (さくら AI Engine / ローカル OpenAI 互換) では false にすると
# JSON 指示 + content フォールバック経路になる (failures.md #29)。
# LLM_USE_TOOLS=true

# Gemini を使う場合 (spec 12 Phase C でネイティブ generateContent 対応):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com   (ネイティブ、自動判定)
#   LLM_MODEL=gemini-2.5-flash
# 従来の OpenAI 互換 (.../v1beta/openai/) も引き続き使える (互換 URL は自動で互換のまま)。
# 認証は x-goog-api-key ヘッダ (キーを URL に載せない)。

# xAI (Grok) を使う場合:
#   LLM_BASE_URL=https://api.x.ai/v1
#   LLM_MODEL=grok-4.3
# tool-use 対応は schema 自己完結化 + authored 専権 op 除外で修正済 (failures.md 参照)。
# grok-4.3/4.5 には reasoning_effort を**既定で明示送出**する (spec 12 Phase D:
# 4.3=none / 4.5=low。未送出だと xAI 既定の思考が max_tokens を食い潰して空デルタ/
# タイムアウトになるため)。LLM_EFFORT で上書き可 (xhigh/max は high へ丸め)。
# 壊れ ops (move to:adjust_stat 等) が残るなら LLM_USE_TOOLS=false との A/B で切り分ける。
# キャッシュは自動だがサーバ単位 — x-grok-conv-id はクライアントが自動送信する (#45)。

# キャッシュ計測を stderr に出す (全プロバイダ)。cached/cache_read > 0 なら効いている。
# LLM_CACHE_DEBUG=1

# 推論の深さ (spec 12 Phase B、opt-in)。設定時のみ Anthropic ネイティブ経路で
# thinking: adaptive + output_config.effort を送る (low / medium / high / xhigh / max)。
# **注意**: Claude 系の max_tokens は思考+本文の合算上限 — effort 設定時は
# LLM_MAX_TOKENS を 16000 以上 (xhigh/max は 64000 目安) に上げること (起動時に警告が出る)。
# LLM_EFFORT=high

# 任意 (既定値あり)
# LLM_TEMPERATURE: 設定すると送信する。**新しめのモデル (claude-opus-4-8 等) は
# temperature 非対応で 400 を返す**ため、既定では送らない (コメントアウトのまま)。
# 旧来モデルで温度を効かせたい時だけ有効化する (LLM_EFFORT との併用は不可 = 対象モデルが 400)。
# LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT_SECS=120
LLM_MAX_RETRIES=3
